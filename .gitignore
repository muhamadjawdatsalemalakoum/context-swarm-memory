# BABILong is fetched at runtime by scripts/fetch-babilong.ts
data/eval/corpus-babilong/

# PaySwift corpus: ship the merged events.jsonl (what src/eval/corpus.ts actually reads)
# + queries.json + decisions + the corpus's own CC0 LICENSE. Exclude the per-tier build
# intermediates that scripts/merge-phase-events.ts consumes to PRODUCE events.jsonl —
# they're regenerable and redundant once events.jsonl exists.
data/eval/corpus-synthetic/events-core.jsonl
data/eval/corpus-synthetic/events-p*.jsonl
data/eval/corpus-synthetic/events-tier*.jsonl
data/eval/corpus-synthetic/queries-batch-*.json
data/eval/corpus-synthetic/queries-stub.json

# Keep src/**/data un-ignored if any source uses it as a fixtures dir
!src/**/data

.venv-mem0/
