# Copy to .env for local use. Never commit real keys.

# Default is mock, which requires no network and no API keys.
CSM_PROVIDER=mock

# Gemini API path. The provider accepts either GEMINI_API_KEY or GOOGLE_API_KEY.
# GEMINI_API_KEY=replace-me
# GOOGLE_API_KEY=replace-me
# CSM_PROVIDER=gemini
# CSM_GEMINI_MODEL=gemini-3-flash-preview

# Local Ollama/Gemma path.
# CSM_PROVIDER=ollama
# CSM_OPENAI_BASE_URL=http://localhost:11434/v1
# CSM_PROBE_MODEL=gemma4:e4b
# CSM_RECALL_MODEL=gemma4:31b
# CSM_SYNTH_MODEL=gemma4:31b

# Hosted OpenAI-compatible path.
# CSM_PROVIDER=openai
# OPENAI_API_KEY=replace-me
# CSM_OPENAI_MODEL=replace-me
