{
  "name": "context-swarm-memory",
  "version": "0.2.0",
  "license": "MIT",
  "description": "R&D prototype: bounded LLM-context memory shards as read-only memory witnesses with explicit Committer-only writes.",
  "type": "module",
  "private": true,
  "bin": {
    "csm": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "csm": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "tsx src/cli/index.ts eval run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "bench:smoke": "tsx src/cli/index.ts bench run --trials 1 --corpus-sizes 100K --model-contexts 8K --queries q01,q11,q28",
    "bench:full": "tsx src/cli/index.ts bench run",
    "bench:confirm": "tsx src/cli/index.ts bench run --systems csm,longctx,rag,hybrid --trials 3 --corpus-sizes 100K,1M --model-contexts 8K",
    "bench:sota:headline": "tsx scripts/sota-headline.ts",
    "bench:sota:scaling": "tsx scripts/sota-scaling.ts",
    "bench:sota:smoke": "tsx src/cli/index.ts bench run --systems csm,lightrag --trials 1 --corpus-sizes 100K --model-contexts 8K --queries q01,q11,q28",
    "bench:sota:sidecars": "tsx src/cli/index.ts bench run --systems csm,lightrag,mem0,hipporag --trials 1 --corpus-sizes 100K --model-contexts 8K",
    "bench:fill-cache": "tsx src/cli/index.ts bench fill-cache",
    "bench:replay": "tsx src/cli/index.ts bench replay",
    "bench:report": "tsx src/cli/index.ts bench report",
    "bench:trials": "tsx scripts/trial-summary.ts",
    "bench:compare": "tsx scripts/compare-runs.ts",
    "verify:published": "tsx scripts/verify-published-claims.ts",
    "proxy:start": "tsx scripts/start-llm-cache-proxy.ts"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "undici": "^8.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tsx": "^4.22.3",
    "typescript": "^5.6.2",
    "vega": "^6.2.0",
    "vega-lite": "^6.4.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20"
  }
}
